generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ----- USER IDENTITY -----
// Mirrors Supabase auth.users. All application FKs reference profiles(id).
// DO NOT reference auth.users(id) directly from application tables.
model Profile {
  id        String   @id @db.Uuid
  email     String   @unique
  role      Role     @default(VIEWER)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  apiKeys   ApiKey[]

  @@map("profiles")
}

enum Role {
  ADMIN
  DEVELOPER
  VIEWER

  @@map("role")
}

// ----- API KEY MANAGEMENT -----
// Plaintext key shown once at creation. Only SHA-256 hash persisted.
// Per-key rate limit overrides: null means use global defaults.
// Phase 4 rate_limit_events table has FK to api_keys(id).
model ApiKey {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profileId      String    @map("profile_id") @db.Uuid
  label          String
  // SHA-256 hash of the plaintext key (hex string, 64 chars)
  keyHash        String    @unique @map("key_hash")
  // Display prefix only — e.g. "sk-...abc4" (first 4 + last 4 chars of plaintext)
  keyPrefix      String    @map("key_prefix")
  // Per-key rate limit overrides. NULL means use global defaults.
  rateLimitRpm   Int?      @map("rate_limit_rpm")
  rateLimitTpm   Int?      @map("rate_limit_tpm")
  expiresAt      DateTime? @map("expires_at") @db.Timestamptz
  lastUsedAt     DateTime? @map("last_used_at") @db.Timestamptz
  revokedAt      DateTime? @map("revoked_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  profile         Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  rateLimitEvents RateLimitEvent[]

  @@index([profileId])
  @@index([keyHash])
  @@map("api_keys")
}

// ----- OBSERVABILITY LAYER -----
// NOTE: request_logs is created as a NATIVE PARTITIONED TABLE via raw SQL migration.
// The Prisma model below maps to the parent table for ORM queries (insert, select).
// Prisma does NOT manage the partitions — they are created via raw SQL in the migration.
// The composite PK (id, created_at) matches the partition key requirement.
model RequestLog {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider        String    // 'openai' | 'anthropic' | 'google'
  model           String    // registry model ID e.g. 'openai:gpt-4o'
  endpoint        String?   // endpoint name e.g. 'summarization', 'classification'
  inputTokens     Int       @default(0) @map("input_tokens")
  outputTokens    Int       @default(0) @map("output_tokens")
  cachedTokens    Int       @default(0) @map("cached_tokens")
  costUsd         Decimal   @default(0) @map("cost_usd") @db.Decimal(10, 8)
  durationMs      Int?      @map("duration_ms")
  status          String    @default("success") // 'success' | 'error' | 'fallback'
  errorCode       String?   @map("error_code")   // 'rate_limit' | 'timeout' | 'model_error'
  isFallback      Boolean   @default(false) @map("is_fallback")
  fallbackReason  String?   @map("fallback_reason")
  promptText      String?   @map("prompt_text")   // H5: required per analysis constraints
  responseText    String?   @map("response_text") // H5: required per analysis constraints
  promptVersionId String?   @map("prompt_version_id") @db.Uuid  // H12: FK added in Phase 3
  sessionId       String?   @map("session_id") @db.Uuid  // COMP-01 deferred, column present
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  promptVersion    PromptVersion?    @relation(fields: [promptVersionId], references: [id])
  // NOTE: No evaluationJobs/evaluationScores relations here — those tables
  // cannot have FK constraints to partitioned request_logs. Use raw queries instead.

  @@index([createdAt, provider, model], name: "request_logs_provider_model_idx")
  @@index([createdAt, costUsd], name: "request_logs_cost_idx")         // M7: Phase 5 alert queries
  @@index([createdAt, durationMs], name: "request_logs_duration_idx")  // M7: Phase 5 alert queries
  @@index([createdAt, status], name: "request_logs_status_idx")        // M7: Phase 5 alert queries
  @@index([promptVersionId, createdAt], name: "request_logs_prompt_version_idx")
  @@map("request_logs")
}

// ----- COST RATE CARDS -----
// Pricing stored in database (not constants) — locked architectural decision.
// Updated without redeployment when providers change pricing.
model CostRateCard {
  id                         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  modelId                    String    @unique @map("model_id")
  provider                   String
  displayName                String    @map("display_name")
  inputPricePerMTokens       Decimal   @map("input_price_per_m_tokens") @db.Decimal(10, 6)
  outputPricePerMTokens      Decimal   @map("output_price_per_m_tokens") @db.Decimal(10, 6)
  cachedInputPricePerMTokens Decimal?  @map("cached_input_price_per_m_tokens") @db.Decimal(10, 6)
  isActive                   Boolean   @default(true) @map("is_active")
  effectiveDate              DateTime  @map("effective_date") @db.Date
  createdAt                  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@map("cost_rate_cards")
}

// ----- DASHBOARD EVENTS -----
// Lightweight table for Supabase Realtime subscriptions.
// pg_cron inserts a row here after each mat view refresh cycle.
// Dashboard subscribes to INSERT events on this table — NOT request_logs.
// Row count: 1 row per 5-min interval = 288 rows/day — trivially small.
model DashboardEvent {
  id        BigInt   @id @default(autoincrement())
  eventType String   @map("event_type") // 'refresh_complete' | 'fallback_occurred' | 'anomaly'
  payload   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("dashboard_events")
}

// ----- ENDPOINT CONFIGS -----
// Per-endpoint model configuration: temperature, max tokens, system prompt, fallback chain.
// Written by Plan 02-04 Config UI. Read by Plan 02-02 model router.
model EndpointConfig {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  endpointName  String   @unique @map("endpoint_name") // e.g. 'summarization', 'chat', 'classification'
  primaryModel  String   @map("primary_model")   // registry ID e.g. 'openai:gpt-4o'
  fallbackChain Json     @default("[]") @map("fallback_chain") // ordered array of model IDs
  temperature   Decimal  @default(0.7) @db.Decimal(3, 2)
  maxTokens     Int      @default(1000) @map("max_tokens")
  systemPrompt  String?  @map("system_prompt")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("endpoint_configs")
}

// ----- PROMPT MANAGEMENT -----
model PromptTemplate {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug            String          @unique
  name            String
  description     String?
  createdBy       String?         @map("created_by") @db.Uuid
  activeVersionId String?         @unique @map("active_version_id") @db.Uuid
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  versions        PromptVersion[] @relation("TemplateVersions")
  activeVersion   PromptVersion?  @relation("ActiveVersion", fields: [activeVersionId], references: [id])

  @@map("prompt_templates")
}

model PromptVersion {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId   String   @map("template_id") @db.Uuid
  version      Int
  content      String   @db.Text
  systemPrompt String?  @map("system_prompt") @db.Text
  modelConfig  Json     @default("{}") @map("model_config")
  variables    Json     @default("[]")
  createdBy    String?  @map("created_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  template     PromptTemplate  @relation("TemplateVersions", fields: [templateId], references: [id], onDelete: Cascade)
  activeFor    PromptTemplate? @relation("ActiveVersion")
  requestLogs  RequestLog[]

  @@unique([templateId, version])
  @@index([templateId, createdAt(sort: Desc)])
  @@map("prompt_versions")
}

// ----- A/B TESTING -----
// Analysis constraint H8: Use simple accumulator columns (latency_sum, latency_sum_sq,
// latency_n) with SELECT ... FOR UPDATE row lock. NOT Welford's algorithm (race condition
// under concurrent SQL writes makes Welford's latency_mean/latency_m2 approach unsafe).
//
// Analysis constraint H9: eval columns are nullable — Phase 5 populates them.
// analysis constraint M9: use overall_score (not final_score) for A/B eval metrics.
// Analysis constraint M11: Use FNV-1a for traffic splitting (not Math.random()).
// Analysis constraint H6: created_by references profiles(id), not auth.users(id).

model Experiment {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  description      String?
  status           String    @default("draft")
  // status values: 'draft' | 'running' | 'stopped' | 'completed'
  hypothesis       String?
  primaryMetric    String    @default("error_rate") @map("primary_metric")
  // primaryMetric: 'error_rate' | 'avg_latency_ms' | 'avg_cost_usd' | 'avg_eval_score'
  mde              Float     // minimum detectable effect (in metric units)
  mdeUnit          String    @default("absolute") @map("mde_unit") // 'absolute' | 'relative'
  alpha            Float     @default(0.05)   // Type I error rate
  beta             Float     @default(0.20)   // Type II error rate
  maxSamples       Int       @default(5000) @map("max_samples")  // SPRT truncation guard
  minSamples       Int       @default(200)  @map("min_samples")  // minimum sample guard
  startedAt        DateTime? @map("started_at") @db.Timestamptz
  stoppedAt        DateTime? @map("stopped_at") @db.Timestamptz
  winnerVariantId  String?   @map("winner_variant_id") @db.Uuid
  createdBy        String    @map("created_by") @db.Uuid  // FK to profiles(id)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  variants         ExperimentVariant[] @relation("ExperimentVariants")
  metrics          VariantMetric[]
  sprtHistory      SprtHistory[]

  @@index([status, startedAt])
  @@map("experiments")
}

model ExperimentVariant {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  experimentId     String   @map("experiment_id") @db.Uuid
  name             String   // 'control' | 'treatment' | 'variant_c'
  promptVersionId  String?  @map("prompt_version_id") @db.Uuid  // FK to prompt_versions(id) — nullable for model-only tests
  modelOverride    String?  @map("model_override")   // override model for this variant
  trafficWeight    Float    @default(0.5) @map("traffic_weight")  // must sum to 1.0 across variants
  isControl        Boolean  @default(false) @map("is_control")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  experiment       Experiment @relation("ExperimentVariants", fields: [experimentId], references: [id], onDelete: Cascade)
  metrics          VariantMetric?

  @@index([experimentId])
  @@map("experiment_variants")
}

// Running statistics per variant.
// H8: Simple accumulator columns (sum + sum_sq + n) — safe for concurrent increments.
// Compute mean and variance at READ time: mean = sum/n, variance = (sum_sq - n*mean^2)/(n-1)
// H9: eval columns nullable — Phase 5 populates them after judge LLM evaluates the request.
// M9: use overall_score (available immediately) for eval_score_sum.
model VariantMetric {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  variantId      String   @unique @map("variant_id") @db.Uuid
  experimentId   String   @map("experiment_id") @db.Uuid

  // Request counts
  requestCount   Int      @default(0) @map("request_count")
  errorCount     Int      @default(0) @map("error_count")

  // Latency accumulators (ms) — H8 pattern
  latencyN       Int      @default(0) @map("latency_n")
  latencySum     Float    @default(0) @map("latency_sum")
  latencySumSq   Float    @default(0) @map("latency_sum_sq")

  // Cost accumulators (USD)
  costN          Int      @default(0) @map("cost_n")
  costSum        Float    @default(0) @map("cost_sum")

  // Eval score accumulators (0-1, from eval_scores.overall_score) — nullable until Phase 5
  evalN          Int?     @map("eval_n")
  evalScoreSum   Float?   @map("eval_score_sum")

  // SPRT state — stored for the primary metric
  sprtLlr        Float    @default(0) @map("sprt_llr")    // cumulative log-likelihood ratio
  sprtDecision   String?  @map("sprt_decision")           // 'continue' | 'accept_h1' | 'accept_h0'
  sprtCheckedAt  DateTime? @map("sprt_checked_at") @db.Timestamptz

  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  variant        ExperimentVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  experiment     Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@index([experimentId])
  @@map("variant_metrics")
}

// SPRT history snapshots — one row per SPRT check (every ~10 new observations)
// Used by the SPRTChart confidence trajectory visualization.
model SprtHistory {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  experimentId   String   @map("experiment_id") @db.Uuid
  sampleCount    Int      @map("sample_count")     // total observations at snapshot time
  llr            Float                             // cumulative log-likelihood ratio
  upperBoundary  Float    @map("upper_boundary")   // ≈ 2.773 for α=0.05
  lowerBoundary  Float    @map("lower_boundary")   // ≈ -1.558 for β=0.20
  recordedAt     DateTime @default(now()) @map("recorded_at") @db.Timestamptz

  experiment     Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@index([experimentId, recordedAt])
  @@map("sprt_history")
}

// ----- RATE LIMITING -----
// Token bucket state per API key bucket (one row per bucket type per key).
// Bucket ID format: "apikey:{api_key_id}:rpm" | "apikey:{api_key_id}:tpm"
// Managed entirely via the check_rate_limit() PL/pgSQL function.
model RateLimitBucket {
  id          String   @id  // composite key e.g. "apikey:{uuid}:rpm"
  tokens      Float         // current token count (can be fractional)
  lastRefill  DateTime @map("last_refill") @db.Timestamptz
  capacity    Int           // max tokens (burst limit)
  refillRate  Float    @map("refill_rate")  // tokens per second
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("rate_limit_buckets")
}

// Degradation event audit log — one row per stage transition per request.
// stage values: 1=queued, 2=fallback_model, 3=cached_response, 4=rejected_429
model RateLimitEvent {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  apiKeyId       String   @map("api_key_id") @db.Uuid
  requestLogId   String?  @map("request_log_id") @db.Uuid  // nullable — may not exist yet
  stage          Int      // 1-4
  stageName      String   @map("stage_name")  // 'queued' | 'fallback_model' | 'cached_response' | 'rejected_429'
  reason         String   // human-readable reason e.g. "rpm_limit_exceeded"
  bucketId       String   @map("bucket_id")   // which bucket triggered this
  tokensAtEvent  Float?   @map("tokens_at_event")   // snapshot for debugging
  queuedMs       Int?     @map("queued_ms")   // stage 1: ms spent in queue
  fallbackModel  String?  @map("fallback_model")  // stage 2: model used
  cacheHitKey    String?  @map("cache_hit_key")  // stage 3: prompt hash
  retryAfterSec  Int?     @map("retry_after_sec")  // stage 4: Retry-After value
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  apiKey         ApiKey   @relation(fields: [apiKeyId], references: [id])

  @@index([apiKeyId, createdAt(sort: Desc)])
  @@index([stage, createdAt(sort: Desc)])
  @@map("rate_limit_events")
}

// Response cache for Stage 3 degradation.
// Populated async via after() on every successful LLM response.
// Looked up by SHA-256 hash of normalized prompt text + model ID.
// H10: This table is new in Phase 4; population logic goes in /api/v1/chat (Phase 2 code).
model ResponseCache {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  promptHash   String    @map("prompt_hash")  // SHA-256 of normalized prompt
  model        String                          // model ID that produced this response
  responseText String    @map("response_text") @db.Text
  inputTokens  Int?      @map("input_tokens")
  outputTokens Int?      @map("output_tokens")
  costUsd      Decimal?  @map("cost_usd") @db.Decimal(10, 6)
  hitCount     Int       @default(0) @map("hit_count")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  lastUsedAt   DateTime  @default(now()) @map("last_used_at") @db.Timestamptz
  expiresAt    DateTime? @map("expires_at") @db.Timestamptz  // optional TTL

  @@unique([promptHash, model])
  @@index([expiresAt], name: "response_cache_expires_idx")
  @@map("response_cache")
}

// ----- EVALUATION (Phase 5) -----
// LLM-as-judge evaluation pipeline.
// Rubrics define scoring dimensions; jobs queue requests for evaluation;
// scores store judge output with dimension breakdown and human review flags.
//
// Analysis constraint C7: evaluation_scores.created_at is REQUIRED.
// Analysis constraint M11: FNV-1a used for sampling (not Math.random()).

model EvaluationRubric {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String   @default("")
  // JSONB array of dimension objects: [{ id, name, description, weight, anchors }]
  dimensions  Json
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  jobs        EvaluationJob[]
  scores      EvaluationScore[]

  @@map("evaluation_rubrics")
}

model EvaluationJob {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // NOTE: no Prisma relation to RequestLog — request_logs is partitioned and does not
  // support FK constraints referencing only id (composite PK includes created_at).
  // Application-layer integrity enforced instead.
  requestId    String    @map("request_id") @db.Uuid
  rubricId     String    @map("rubric_id") @db.Uuid
  status       String    @default("pending") // pending | in_progress | completed | failed
  attemptCount Int       @default(0) @map("attempt_count")
  lastError    String?   @map("last_error")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  startedAt    DateTime? @map("started_at") @db.Timestamptz
  completedAt  DateTime? @map("completed_at") @db.Timestamptz

  rubric       EvaluationRubric @relation(fields: [rubricId], references: [id])
  score        EvaluationScore?

  @@index([status, createdAt], name: "idx_eval_jobs_status_created")
  @@map("evaluation_jobs")
}

model EvaluationScore {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // NOTE: no Prisma relation to RequestLog — request_logs is partitioned and does not
  // support FK constraints referencing only id (composite PK includes created_at).
  // Application-layer integrity enforced instead.
  requestId               String    @map("request_id") @db.Uuid
  rubricId                String    @map("rubric_id") @db.Uuid
  jobId                   String    @unique @map("job_id") @db.Uuid
  judgeModel              String    @default("gpt-4o") @map("judge_model")
  // JSONB: { "accuracy": 4, "coherence": 3, "safety": 5 }
  dimensionScores         Json      @map("dimension_scores")
  overallScore            Decimal   @map("overall_score") @db.Decimal(3, 2)
  reasoning               String
  flags                   String[]  @default([])
  requiresHumanReview     Boolean   @default(false) @map("requires_human_review")
  humanReviewed           Boolean   @default(false) @map("human_reviewed")
  humanReviewerId         String?   @map("human_reviewer_id") @db.Uuid
  humanReviewNotes        String?   @map("human_review_notes")
  // JSONB: { "accuracy": 3, "coherence": 4 } — only overridden dimensions
  humanDimensionOverrides Json?     @map("human_dimension_overrides")
  // overall_score if not human-reviewed; human-computed weighted avg if reviewed
  finalScore              Decimal?  @map("final_score") @db.Decimal(3, 2)
  finalScoredAt           DateTime? @map("final_scored_at") @db.Timestamptz
  // REQUIRED by ANALYSIS-REPORT constraint C7
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz

  rubric   EvaluationRubric @relation(fields: [rubricId], references: [id])
  job      EvaluationJob    @relation(fields: [jobId], references: [id])

  @@index([requestId], name: "idx_eval_scores_request")
  @@index([requiresHumanReview, humanReviewed], name: "idx_eval_scores_review")
  @@map("evaluation_scores")
}

