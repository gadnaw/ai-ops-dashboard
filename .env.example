# =============================================================================
# AI Ops Dashboard — Environment Variables
# Copy this file to .env.local and fill in your values.
# =============================================================================

# --- Database (Supabase PostgreSQL) ---
# Pooled connection string — use for all runtime Prisma queries
# Port 6543, PgBouncer enabled, connection_limit=1 required for serverless
# Format: postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://..."

# Direct connection string — use for Prisma migrations only
# Port 5432, bypasses PgBouncer
# Format: postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DIRECT_URL="postgresql://..."

# --- Supabase ---
# Found at: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# Anon key — safe to expose to browser (RLS enforces security)
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Service role key — SERVER ONLY. Never expose to browser or prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# --- OAuth Providers (configured in Supabase Dashboard > Auth > Providers) ---
# GitHub OAuth App: https://github.com/settings/developers
# Set callback URL to: https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Google OAuth: https://console.cloud.google.com/apis/credentials
# Set callback URL to: https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- LLM Provider API Keys (SERVER ONLY — never prefix with NEXT_PUBLIC_) ---
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# Anthropic: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""

# Google AI Studio: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=""

# =============================================================================
# VERCEL DEPLOYMENT NOTES
# =============================================================================
# Set all variables above in Vercel Dashboard > Project > Settings > Environment Variables
# OR use the Vercel CLI: vercel env add VAR_NAME production
#
# Build command in vercel.json: "pnpm db:migrate && pnpm build"
# - pnpm db:migrate runs "prisma migrate deploy" using DIRECT_URL
# - DIRECT_URL must be the port 5432 direct connection (not pooled)
# - DATABASE_URL uses port 6543 pooled connection at runtime
#
# Preview deployments: automatic on all PRs (no config needed)
# Production: push to main branch
