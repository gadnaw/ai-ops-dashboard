# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment files — never commit
.env
.env.local
.env.*.local

# env files (can opt-in for committing if needed)
.env*
# But always commit the example file
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# OS
Thumbs.db

# Planning checkpoints (transient session state)
.planning/checkpoints/

.vercel
.mcp.json

.env*.local

# Claude Code local settings
.claude/

# Planning internal artifacts (dev tooling, not source code)
.planning/memory/
.planning/toolkit/
.planning/health/
.planning/dependencies/
.planning/checkpoints/
.planning/DEPLOY-PLAN.md
.planning/DEPLOY-REPORT.md
.planning/DEPLOY-RUNBOOK.md

# Root-level planning docs (duplicated in .planning/)
CATALOG.md
FEATURES.md
PROJECT.md
REQUIREMENTS.md

# Supabase temp files
supabase/.temp/
